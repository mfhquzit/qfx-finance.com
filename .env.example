DATABASE_URL=postgresql://user:password@localhost:5432/qfx_finance

# JWT Configuration
JWT_SECRET=your-secret-key-here-min-32-characters
JWT_EXPIRATION=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@qfx-finance.com

# 2FA Configuration
TWO_FACTOR_ENABLED=true
TWO_FACTOR_ISSUER=QFX Finance

# Admin Configuration
ADMIN_EMAIL=admin@qfx-finance.com
ADMIN_PASSWORD=ChangeMe123!

# External APIs
COINGECKO_API_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Crypto Configuration
WALLET_NETWORK=ethereum
WALLET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/demo

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIRECTORY=./uploads