# Database
DATABASE_URL="postgresql://user:password@localhost:5432/qfx_finance"
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="qfx_finance"
DATABASE_USER="qfx_user"
DATABASE_PASSWORD="your_secure_password"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# JWT Authentication
JWT_SECRET="generate-with-openssl-rand-base64-64"
JWT_EXPIRATION="24h"
JWT_REFRESH_SECRET="another-strong-secret"
JWT_REFRESH_EXPIRATION="7d"

# Application
NODE_ENV="development"
PORT="3000"
APP_NAME="qfx-api"
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Stripe Payment Integration
STRIPE_API_KEY="sk_test_your_test_key"
STRIPE_PUBLIC_KEY="pk_test_your_test_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Email Configuration (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="noreply@qfx-finance.com"
EMAIL_FROM_NAME="QFX Finance"

# 2FA/TOTP
TOTP_WINDOW="1"
TOTP_TIME_STEP="30"

# Logging
LOG_LEVEL="debug"
LOG_FORMAT="json"

# Security
BCRYPT_ROUNDS="10"
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX_REQUESTS="100"

# Admin Account (created during seeding)
ADMIN_EMAIL="admin@qfx-finance.com"
ADMIN_PASSWORD="AdminPassword123!"

# Crypto APIs
COINGECKO_API_KEY="optional_api_key"
BINANCE_API_KEY="optional_binance_key"
BINANCE_API_SECRET="optional_binance_secret"

# Web3 & Wallets
WEB3_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/your-api-key"
WALLET_PRIVATE_KEY="optional_private_key_for_automation"
